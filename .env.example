# MCP Server — environment variables.
#
# Copy this file to `.env.local` and fill in the values for your
# vendor account / tenant. `.env.local` is gitignored. Never commit
# real credentials.
#
# Each adopter creates their own credentials in the vendor's admin
# portal (Microsoft Entra, Aruba console, Finom developer portal, etc.).
# The MCP server is tenant/account-agnostic — it reads these at startup
# and authenticates as whatever credentials you've set.
#
# See README.md § Environment variables for the list of variables
# required by this MCP server.

# Required: rename and fill in the env var(s) your vendor authentication
# needs. Example:
#   <VENDOR>_API_KEY=<your-api-key-value>

# Optional: log level for diagnostics on stderr (default: info).
MCP_SERVER_LOG_LEVEL=info
