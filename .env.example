# M365 Mail MCP Server — environment variables.
#
# Copy this file to `.env.local` and fill in the values for your tenant.
# `.env.local` is gitignored. Never commit real credentials.
#
# Each adopter creates their OWN Entra app registration for this
# server. The env vars are deliberately namespaced (`M365_MAIL_*`) so
# a config-file typo cannot silently reuse the sibling
# `m365-graph-mcp-server`'s app credentials (whose vars are `M365_*`)
# and thereby escalate scopes across servers. Isolation is the point.
#
# See README.md § Environment variables and § Local development for
# the full Entra setup flow.

# Microsoft Entra tenant ID (UUID), or `common` / `organizations` /
# `consumers` for multi-tenant flows. Validated at startup.
M365_MAIL_TENANT_ID=<your tenant UUID>

# Application (client) ID from the Entra app registration "Overview".
M365_MAIL_CLIENT_ID=<your app registration client ID>

# Client secret VALUE (not Secret ID). Set in Entra → Certificates & secrets.
# Microsoft only shows this once at creation time; treat as a password.
M365_MAIL_CLIENT_SECRET=<your client secret>

# Optional: attachment download sandbox root. Defaults to
# $XDG_CACHE_HOME/m365-mail-mcp-server (or ~/.cache/m365-mail-mcp-server).
# Every attachment lands under <root>/<tenant-id>/ with a
# server-controlled filename. Deliberately distinct from the
# m365-graph server's cache directory.
# M365_MAIL_DOWNLOAD_DIR=/absolute/path

# Optional: log level for diagnostics on stderr (default: info).
MCP_SERVER_LOG_LEVEL=info
