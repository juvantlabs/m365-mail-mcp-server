{
  "name": "@juvantlabs/m365-mail-mcp-server",
  "version": "0.2.1",
  "description": "Microsoft 365 Outlook Mail via delegated Microsoft Graph: read messages, folders and attachments, and author/manage drafts (send is a later gated phase).",
  "license": "MIT",
  "author": "Juvant Srls",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "m365-mail-mcp-server": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "ARCHITECTURE.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --pretty false",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test:unit && npm run build",
    "start": "node dist/index.js",
    "dev": "tsx --env-file=.env.local src/index.ts",
    "setup": "tsx --env-file=.env.local src/index.ts setup",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit --passWithNoTests",
    "test:integration": "node --env-file=.env.local node_modules/.bin/vitest run tests/integration --passWithNoTests 2>/dev/null || vitest run tests/integration --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src tests --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit --audit-level=moderate"
  },
  "dependencies": {
    "@azure/msal-node": "^5.0.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@napi-rs/keyring": "^1.3.0",
    "isomorphic-fetch": "^3.0.0"
  },
  "overrides": {
    "ip-address": ">=10.2.0"
  },
  "devDependencies": {
    "@types/isomorphic-fetch": "^0.0.39",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juvantlabs/m365-mail-mcp-server.git"
  },
  "homepage": "https://github.com/juvantlabs/m365-mail-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/juvantlabs/m365-mail-mcp-server/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "m365-mail",
    "outlook",
    "juvant-os"
  ]
}
